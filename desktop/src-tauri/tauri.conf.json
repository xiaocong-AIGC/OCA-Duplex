{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OCA-Duplex",
  "version": "0.4.0",
  "identifier": "app.ocaduplex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "OCA-Duplex",
      "width": 1440,
      "height": 900,
      "minWidth": 1024,
      "minHeight": 700,
      "center": true,
      "decorations": true,
      "resizable": true
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/oca-duplex-sidecar"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"]
  }
}
